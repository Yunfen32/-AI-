# Life Monster 环境配置
# 复制此文件为 .env 并填写真实值

# 阿里云通义千问 API 配置
# 获取地址: https://dashscope.console.aliyun.com/apiKey
ALIBABA_API_KEY=your_api_key_here
ALIBABA_MODEL=qwen-turbo

# MySQL 数据库配置
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=dk

# Redis 配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Flask 配置（可选）
FLASK_SECRET_KEY=your_secret_key
FLASK_DEBUG=True

# 应用模式
# mock: 使用模拟数据（不需要真实API）
# live: 使用真实API
APP_MODE=mock
